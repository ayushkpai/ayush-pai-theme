{
  "name": "Ayush Pai Theme",
  "type": "dark",

  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#e5e7eb",

    "editorCursor.foreground": "#ffffff",

    "editor.selectionBackground": "#93c5fd66",
    "editor.selectionHighlightBackground": "#bfdbfe44",
    "editor.lineHighlightBackground": "#ffffff14",

    "editorLineNumber.foreground": "#475569",
    "editorLineNumber.activeForeground": "#ffffff",

    "activityBar.background": "#000000",

    "activityBar.foreground": "#9CDCFE",
    "activityBar.inactiveForeground": "#6b7280",
    "activityBar.activeForeground": "#9CDCFE",

    "activityBar.activeBorder": "#a855f7",
    "activityBarBadge.background": "#a855f7",
    "activityBarBadge.foreground": "#ffffff",

    "sideBar.background": "#000000",
    "sideBar.foreground": "#e5e7eb",
    "sideBar.border": "#111111",

    "panel.background": "#0f172a",
    "panel.border": "#1e293b",

    "terminal.background": "#0f172a",
    "terminal.foreground": "#ffffff",
    "terminalCursor.foreground": "#a855f7",

    "statusBar.background": "#fbcfe8",
    "statusBar.foreground": "#111827",

    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#ffffff",

    "tab.activeBackground": "#111827",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#94a3b8",
    "tab.activeBorder": "#a855f7",

    "button.background": "#a855f7",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#9333ea",

    "badge.background": "#a855f7",
    "badge.foreground": "#ffffff",

    "textLink.foreground": "#a855f7",
    "focusBorder": "#a855f7",

    "input.background": "#111827",
    "input.foreground": "#ffffff",
    "input.border": "#374151",

    "list.hoverBackground": "#1f2937",
    "list.activeSelectionBackground": "#312e81",
    "list.activeSelectionForeground": "#ffffff",

    "editor.findMatchBackground": "#a855f755",
    "editor.findMatchHighlightBackground": "#a855f733",
    "editor.findMatchBorder": "#a855f7",

    "editorHoverWidget.background": "#111827",
    "editorHoverWidget.border": "#a855f7",

    "notifications.background": "#111827",
    "notifications.foreground": "#ffffff",

    "scrollbarSlider.background": "#a855f744",
    "scrollbarSlider.hoverBackground": "#a855f777",
    "scrollbarSlider.activeBackground": "#a855f7aa",

    "minimap.background": "#0f172a"
  },

  "semanticHighlighting": true,

  "semanticTokenColors": {
    "variable": "#9CDCFE",
    "parameter": "#9CDCFE",
    "property": "#D4D4D4",

    "function": "#1d4ed8",
    "method": "#1d4ed8",

    "class": "#2563eb",
    "type": "#2563eb",

    "interface": "#2563eb",
    "enum": "#2563eb",

    "keyword": "#7c3aed",
    "string": "#ef4444",
    "number": "#f472b6",
    "operator": "#a855f7",

    "comment": "#475569"
  },

  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#475569",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#ef4444"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": "constant",
      "settings": {
        "foreground": "#db2777"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": "type",
      "settings": {
        "foreground": "#2563eb"
      }
    },
    {
      "scope": "class",
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "scope": ["parameter", "variable.parameter"],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": ["property", "variable.object.property"],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": "operator",
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": {
        "foreground": "#2563eb"
      }
    }
  ]
}

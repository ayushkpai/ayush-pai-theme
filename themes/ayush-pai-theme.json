{
  "name": "Ayush Pai Theme",
  "type": "dark",

  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#e5e7eb",
    "editorCursor.foreground": "#a855f7",

    "editor.selectionBackground": "#93c5fd33",
    "editor.selectionHighlightBackground": "#a855f744",
    "editor.lineHighlightBackground": "#ffffff10",

    "editorLineNumber.foreground": "#475569",
    "editorLineNumber.activeForeground": "#a855f7",

    "activityBar.background": "#000000",
    "activityBar.foreground": "#93c5fd",
    "activityBar.inactiveForeground": "#64748b",
    "activityBar.activeForeground": "#a855f7",
    "activityBar.activeBorder": "#a855f7",
    "activityBarBadge.background": "#a855f7",
    "activityBarBadge.foreground": "#ffffff",

    "sideBar.background": "#000000",
    "sideBar.foreground": "#e5e7eb",
    "sideBar.border": "#111111",

    "panel.background": "#0f172a",
    "panel.border": "#1e293b",

    "panelTitle.activeForeground": "#a855f7",
    "panelTitle.inactiveForeground": "#93c5fd",
    "panelTitle.border": "#1e293b",

    "panelSection.border": "#1e293b",
    "panelSectionHeader.background": "#0f172a",
    "panelSectionHeader.foreground": "#93c5fd",

    "tab.activeForeground": "#a855f7",
    "tab.inactiveForeground": "#93c5fd",
    "tab.hoverForeground": "#93c5fd",

    "tab.activeBackground": "#111827",
    "tab.inactiveBackground": "#000000",
    "tab.hoverBackground": "#1f2937",

    "tab.activeBorder": "#a855f7",
    "tab.unfocusedActiveBorder": "#a855f7",
    "tab.border": "#111111",

    "list.background": "#000000",
    "list.foreground": "#e5e7eb",
    "list.hoverBackground": "#111827",
    "list.hoverForeground": "#93c5fd",
    "list.activeSelectionBackground": "#111827",
    "list.activeSelectionForeground": "#a855f7",
    "list.highlightForeground": "#a855f7",

    "terminal.background": "#000000",
    "terminal.foreground": "#93c5fd",
    "terminalCursor.foreground": "#a855f7",

    "debugConsole.infoForeground": "#93c5fd",
    "debugConsole.sourceForeground": "#e5e7eb",
    "debugConsole.warningForeground": "#facc15",
    "debugConsole.errorForeground": "#ef4444",

    "statusBar.background": "#000000",
    "statusBar.foreground": "#e5e7eb",

    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#ffffff",

    "button.background": "#a855f7",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#9333ea",

    "badge.background": "#a855f7",
    "badge.foreground": "#ffffff",

    "textLink.foreground": "#93c5fd",
    "textLink.activeForeground": "#a855f7",

    "focusBorder": "#a855f7",

    "input.background": "#111827",
    "input.foreground": "#ffffff",
    "input.border": "#374151",

    "editor.findMatchBackground": "#a855f733",
    "editor.findMatchHighlightBackground": "#a855f744",
    "editor.findMatchBorder": "#a855f7",

    "editorHoverWidget.background": "#111827",
    "editorHoverWidget.border": "#a855f7",

    "notifications.background": "#111827",
    "notifications.foreground": "#ffffff",

    "scrollbarSlider.background": "#a855f744",
    "scrollbarSlider.hoverBackground": "#a855f777",
    "scrollbarSlider.activeBackground": "#a855f7aa",

    "minimap.background": "#1e1e1e"
  },

  "semanticHighlighting": true,

  "semanticTokenColors": {
    "variable": "#9CDCFE",
    "parameter": "#9CDCFE",
    "property": "#e5e7eb",
    "function": "#a855f7",
    "method": "#a855f7",
    "class": "#93c5fd",
    "type": "#93c5fd",
    "interface": "#93c5fd",
    "enum": "#93c5fd",
    "keyword": "#a855f7",
    "string": "#ef4444",
    "number": "#f472b6",
    "operator": "#a855f7",
    "comment": "#64748b"
  },

  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#ef4444"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a855f7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#93c5fd"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "variable.language"
      ],
      "settings": {
        "foreground": "#e5e7eb"
      }
    },
    {
      "scope": [
        "variable.other.object",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#6a77d8"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": [
        "operator",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#dddfe9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#eb58e3"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#6a77d8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#93c5fd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.raw",
        "markup.fenced_code",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#eb58e3"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#c4cbff"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#01d648"
      }
    }
  ]
}
